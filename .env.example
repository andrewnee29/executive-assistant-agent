# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# App
SECRET_KEY=change-me-to-a-random-string
DEBUG=false

# LLM Provider
# Set to "anthropic" or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-6

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Database
# SQLite for local dev — swap for Postgres in production
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/executive_assistant
